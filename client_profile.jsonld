{
  "@context": "https://www.w3.org/ns/solid/oidc-context.jsonld",
  "client_id": "https://gisborne.github.io/solid_auth/client_profile.jsonld",
  "client_name": "MyPodApp",
  "application_type": "native",
  "redirect_uris": [
    "https://gisborne.github.io/solid_auth/redirect.html"
  ],
  "post_logout_redirect_uris": [
    "https://gisborne.github.io/solid_auth/redirect.html",
    "com.example.mypodapp://redirect",
    "http://localhost:4400/redirect"
  ],
  "scope": "openid profile offline_access webid",
  "grant_types": [
    "authorization_code",
    "refresh_token"
  ],
  "response_types": [
    "code"
  ],
  "token_endpoint_auth_method": "none"
}
